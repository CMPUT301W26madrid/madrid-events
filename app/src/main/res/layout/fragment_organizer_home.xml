<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <TextView
        android:id="@+id/text_my_events"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="My Events"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_logout"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="Logout"
        android:src="@android:drawable/ic_lock_power_off"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/text_my_events"
        app:layout_constraintEnd_toStartOf="@+id/btn_create_new_event"
        app:layout_constraintTop_toTopOf="@+id/text_my_events"
        app:tint="#DC2626" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_create_new_event"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:backgroundTint="#2563EB"
        android:src="@android:drawable/ic_input_add"
        app:fabCustomSize="52dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="@+id/text_my_events"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_my_events"
        app:tint="@android:color/white" />

    <ImageButton
        android:id="@+id/btn_facility_profile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@android:color/transparent"
        android:contentDescription="Facility Profile"
        android:src="@android:drawable/ic_menu_myplaces"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/text_my_events"
        app:layout_constraintEnd_toStartOf="@+id/btn_logout"
        app:layout_constraintTop_toTopOf="@+id/text_my_events"
        app:tint="#111827" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_my_events"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_my_events" />

</androidx.constraintlayout.widget.ConstraintLayout>
